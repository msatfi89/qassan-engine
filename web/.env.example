# Copy to .env.local for local development. NEVER commit .env.local.
# On Vercel these go in Project Settings -> Environment Variables.

# The dashboard password. Use something long and random — it is the only
# thing between the internet and the approval queue.
#   node -e "console.log(require('crypto').randomBytes(18).toString('base64url'))"
ADMIN_PASSWORD=

# Signs the session cookie. Must be at least 32 characters; the app refuses
# to start a session otherwise. Generate a different value from the password:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_SESSION_SECRET=

SUPABASE_URL=

# Dashboard and report writes only. Bypasses row-level security by design, so
# it must never be prefixed NEXT_PUBLIC_ or imported by a client component —
# lib/supabase.ts imports "server-only" to make that a build error.
SUPABASE_SERVICE_KEY=

# Public feed. Supabase calls this the "publishable" key now (sb_publishable_…);
# it is the old "anon" key. It respects row-level security, which is what makes
# the approval gate enforceable by the database rather than by the query.
SUPABASE_ANON_KEY=
