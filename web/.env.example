# Copy to .env.local for local development. NEVER commit .env.local.
# On Vercel these go in Project Settings -> Environment Variables.

# The dashboard password. Use something long and random — it is the only
# thing between the internet and the approval queue.
#   node -e "console.log(require('crypto').randomBytes(18).toString('base64url'))"
ADMIN_PASSWORD=

# Signs the session cookie. Must be at least 32 characters; the app refuses
# to start a session otherwise. Generate a different value from the password:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_SESSION_SECRET=

# Added in piece 2, when the dashboard starts reading the queue.
# SUPABASE_SERVICE_KEY is server-only: it bypasses row-level security, so it
# must never be prefixed NEXT_PUBLIC_ or referenced from a client component.
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
